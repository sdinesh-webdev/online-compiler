  function registerTailwindCompletions() {
    const triggerRegex = /(?:className|class)\s*=\s*["'`]([^"'`]*)$/;

    const provider: monaco.languages.CompletionItemProvider = {
      triggerCharacters: ['"', "'", '`', ' ', '-'],
      provideCompletionItems(model, position) {
        const textUntilPosition = model.getValueInRange({
          startLineNumber: position.lineNumber,
          startColumn: 1,
          endLineNumber: position.lineNumber,
          endColumn: position.column,
        });

        const match = triggerRegex.exec(textUntilPosition);
        if (!match) return { suggestions: [] };

        const classStr = match[1];
        const lastSpace = classStr.lastIndexOf(' ');
        const currentWord = classStr.substring(lastSpace + 1);
        const wordRange = new monaco.Range(
          position.lineNumber,
          position.column - currentWord.length,
          position.lineNumber,
          position.column,
        );

        const suggestions: monaco.languages.CompletionItem[] = TAILWIND_CLASSES
          .filter(cls => cls.toLowerCase().startsWith(currentWord.toLowerCase()))
          .map(cls => ({
            label: cls,
            kind: monaco.languages.CompletionItemKind.Value,
            insertText: cls,
            range: wordRange,
            detail: 'Tailwind CSS',
            documentation: { value: `\`${cls}\`` },
            sortText: '00' + cls,
          }));

        return { suggestions };
      }
    };

    ['javascript', 'typescript', 'html'].forEach(lang => {
      monaco.languages.registerCompletionItemProvider(lang, provider);
    });
  }

  registerTailwindCompletions();

  // ── Virtual File System ───────────────────────────────────────────────────
  type VfsNode = { id: string, name: string, type: 'file' | 'folder', content?: string, parentId: string | null };
  let vfs: VfsNode[] = [];
  let activeFileId: string | null = null;
  let activeFolderId: string | null = null;
  let creatingItem: { type: 'file' | 'folder', parentId: string | null } | null = null;
  let renamingItemId: string | null = null;

  function initVFS() {
    const saved = localStorage.getItem('ag_vfs_state');
    if (saved) {
      try { vfs = JSON.parse(saved); } catch {}
    }
    
    if (vfs.length === 0) {
      vfs.push(
        { id: 'f-html', name: 'index.html', type: 'file', content: '<!DOCTYPE html>\n<html lang="en">\n<head>\n  <meta charset="UTF-8">\n  <title>App</title>\n  <link rel="stylesheet" href="style.css">\n</head>\n<body>\n  <div id="app">Hello, world!</div>\n  <script src="main.js"><\\/script>\n</body>\n</html>\n', parentId: null },
        { id: 'f-css', name: 'style.css', type: 'file', content: 'body {\n  font-family: sans-serif;\n  background: #1e1e1e;\n  color: #fff;\n  margin: 0;\n  padding: 20px;\n}\n', parentId: null },
        { id: 'f-main', name: 'main.js', type: 'file', content: '// Write your JavaScript here\nconsole.log("Hello, world!");\n', parentId: null }
      );
      saveVFS();
    }
    renderVFS();
    
    if (!activeFileId) {
      const firstFile = vfs.find(n => n.type === 'file');
      if (firstFile) openFile(firstFile.id);
    }
  }

  function saveVFS() {
    localStorage.setItem('ag_vfs_state', JSON.stringify(vfs));
  }

  function showEditorToast(message: string, isError: boolean = false) {
    const toast = document.createElement('div');
    const bgColor = isError ? 'bg-red-900/40 border-red-500/50 text-red-100' : 'bg-[#1e1e1e] border-[#333] text-white';
    const icon = isError 
      ? `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 8v4m0 4h.01"/></svg>`
      : `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>`;
      
    toast.className = `fixed bottom-4 right-4 ${bgColor} border px-4 py-3 rounded shadow-xl text-[13px] z-[9999] flex items-center gap-3 transition-all duration-300 translate-y-4 opacity-0`;
    toast.innerHTML = `${icon} <span>${message}</span>`;
    document.body.appendChild(toast);
    
    toast.getBoundingClientRect();
    
    toast.classList.remove('translate-y-4', 'opacity-0');
    
    setTimeout(() => {
      toast.classList.add('translate-y-4', 'opacity-0');
      setTimeout(() => toast.remove(), 300);
    }, 3000);
  }

  function getFileIcon(name: string, type: 'file' | 'folder') {
    if (type === 'folder') return `<svg width="14" height="14" viewBox="0 0 24 24" fill="#dcb67a"><path d="M10 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2h-8l-2-2z"/></svg>`;
    if (name.endsWith('.js')) return `<svg width="14" height="14" viewBox="0 0 24 24" fill="#f7df1e"><rect x="3" y="3" width="18" height="18" rx="2"/><text x="13.5" y="17" font-family="Arial" font-size="11" font-weight="bold" fill="#000" text-anchor="middle">JS</text></svg>`;
    if (name.endsWith('.ts')) return `<svg width="14" height="14" viewBox="0 0 24 24" fill="#3178c6"><rect x="3" y="3" width="18" height="18" rx="2"/><text x="13.5" y="17" font-family="Arial" font-size="11" font-weight="bold" fill="#fff" text-anchor="middle">TS</text></svg>`;
    if (name.endsWith('.jsx') || name.endsWith('.tsx')) return `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#61dafb" stroke-width="2"><circle cx="12" cy="12" r="2" fill="#61dafb"/><ellipse cx="12" cy="12" rx="10" ry="3.5" transform="rotate(30 12 12)"/><ellipse cx="12" cy="12" rx="10" ry="3.5" transform="rotate(90 12 12)"/><ellipse cx="12" cy="12" rx="10" ry="3.5" transform="rotate(150 12 12)"/></svg>`;
    if (name.endsWith('.html')) return `<svg width="14" height="14" viewBox="0 0 24 24" fill="#E34F26"><path d="m3 2 1.578 17.824L12 22l7.467-2.175L21 2H3Zm14.049 6.048H9.075l.172 2.016h7.697l-.626 6.565-4.246 1.381-4.281-1.455-.288-2.932h2.024l.16 1.411 2.4.815 2.346-.763.297-3.005H7.416l-.562-6.05h10.412l-.217 2.017Z"/></svg>`;
    if (name.endsWith('.css')) return `<svg width="14" height="14" viewBox="0 0 128 128"><path fill="#1572B6" d="M18.814 114.123L8.76 1.352h110.48l-10.064 112.754-45.243 12.543-45.119-12.526z"/><path fill="#33A9DC" d="M64.001 117.062l36.559-10.136 8.601-96.354h-45.16v106.49z"/><path fill="#fff" d="M64.001 51.429h18.302l1.264-14.163H64.001V23.435h34.682l-.332 3.711-3.4 38.114h-30.95V51.429z"/><path fill="#EBEBEB" d="M64.083 87.349l-.061.018-15.403-4.159-.985-11.031H33.752l1.937 21.717 28.331 7.863.063-.018v-14.39z"/><path fill="#fff" d="M81.127 64.675l-1.666 18.522-15.426 4.164v14.39l28.354-7.858.208-2.337 2.406-26.881H81.127z"/><path fill="#EBEBEB" d="M64.048 23.435v13.831H30.64l-.277-3.108-.63-7.012-.331-3.711h34.646zm-.047 27.996v13.831H48.792l-.277-3.108-.631-7.012-.33-3.711h16.447z"/></svg>`;
    return `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#cccccc" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>`;
  }

  function renderVFS() {
    const tree = document.getElementById('vfs-tree');
    if (!tree) return;
    tree.innerHTML = '';
    
    tree.onclick = () => {
      activeFolderId = null;
      if (renamingItemId) renamingItemId = null;
      renderVFS();
    };

    const rootNodes = vfs.filter(n => n.parentId === null);
    
    const renderNode = (node: VfsNode, level: number, container: HTMLElement) => {
      const el = document.createElement('div');
      el.className = 'flex items-center gap-1.5 px-2 py-[5px] cursor-pointer select-none transition-colors hover:bg-white/5 group relative';
      el.style.paddingLeft = `${level * 12 + 8}px`;
      if (node.id === activeFileId || node.id === activeFolderId) {
        el.style.background = 'rgba(255,255,255,0.1)';
      }
      
      const icon = document.createElement('span');
      icon.className = 'flex items-center justify-center shrink-0 w-[14px] h-[14px]';
      icon.innerHTML = getFileIcon(node.name, node.type);
      
      el.appendChild(icon);
      
      if (renamingItemId === node.id) {
        const input = document.createElement('input');
        input.type = 'text';
        input.className = 'flex-1 bg-transparent border border-[#007acc] text-[13px] outline-none text-white px-1';
        input.value = node.name;
        
        input.addEventListener('input', () => {
          icon.innerHTML = getFileIcon(input.value.trim(), node.type);
        });
        
        let committed = false;
        const commit = () => {
          if (committed) return;
          committed = true;
          const newName = input.value.trim();
          if (newName && newName !== node.name) {
            if (vfs.some(n => n.name === newName && n.parentId === node.parentId && n.id !== node.id)) {
              showEditorToast(`A ${node.type} named "${newName}" already exists in this folder.`, true);
              renamingItemId = null;
              renderVFS();
              return;
            }
            node.name = newName;
            saveVFS();
            // Update editor tab label if active file is renamed
            if (activeFileId === node.id) {
              const label = document.getElementById('editor-title-label');
              if (label) label.textContent = newName;
            }
          }
          renamingItemId = null;
          renderVFS();
        };
        
        input.onkeydown = (e) => {
          if (e.key === 'Enter') commit();
          if (e.key === 'Escape') { renamingItemId = null; renderVFS(); }
        };
        input.onblur = commit;
        
        el.appendChild(input);
        
        // Let it render then focus
        setTimeout(() => {
          input.focus();
          const dotIdx = input.value.lastIndexOf('.');
          if (dotIdx > 0) input.setSelectionRange(0, dotIdx);
          else input.select();
        }, 0);
      } else {
        const label = document.createElement('span');
        label.className = 'text-[13px] truncate flex-1';
        label.style.color = 'var(--vscode-text)';
        label.textContent = node.name;
        el.appendChild(label);
      }
      
      const actions = document.createElement('div');
      actions.className = 'hidden group-hover:flex items-center gap-1 absolute right-2 bg-[var(--vscode-sidebar)] px-1';
      
      if (renamingItemId !== node.id) {
        const renameBtn = document.createElement('button');
        renameBtn.className = 'w-[18px] h-[18px] flex items-center justify-center rounded border-none cursor-pointer hover:bg-white/10';
        renameBtn.style.color = 'var(--vscode-text-dim)';
        renameBtn.style.background = 'transparent';
        renameBtn.title = "Rename";
        renameBtn.innerHTML = `<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>`;
        renameBtn.onclick = (e) => {
          e.stopPropagation();
          renamingItemId = node.id;
          renderVFS();
        };
        actions.appendChild(renameBtn);
      }
      
      const delBtn = document.createElement('button');
      delBtn.className = 'w-[18px] h-[18px] flex items-center justify-center rounded border-none cursor-pointer hover:bg-red-500/80';
      delBtn.style.color = 'var(--vscode-text-dim)';
      delBtn.style.background = 'transparent';
      delBtn.title = "Delete";
      delBtn.innerHTML = `<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>`;
      delBtn.onclick = (e) => {
        e.stopPropagation();
        deleteNode(node.id);
      };
      
      if (renamingItemId !== node.id) actions.appendChild(delBtn);
      
      if (renamingItemId !== node.id) el.appendChild(actions);
      
      el.onclick = (e) => {
        e.stopPropagation();
        if (renamingItemId === node.id) return;
        if (node.type === 'file') {
          activeFolderId = null;
          openFile(node.id);
        } else {
          activeFolderId = activeFolderId === node.id ? null : node.id;
          renderVFS();
        }
      };
      
      container.appendChild(el);
      
      if (node.type === 'folder') {
        if (creatingItem && creatingItem.parentId === node.id) {
          renderInlineInput(creatingItem.type, creatingItem.parentId, container, level + 1);
        }
        const children = vfs.filter(n => n.parentId === node.id);
        children.forEach(child => renderNode(child, level + 1, container));
      }
    };
    
    // Sort folders first, then files
    rootNodes.sort((a, b) => {
      if (a.type === b.type) return a.name.localeCompare(b.name);
      return a.type === 'folder' ? -1 : 1;
    });
    
    rootNodes.forEach(node => renderNode(node, 0, tree));
    
    if (creatingItem && creatingItem.parentId === null) {
      renderInlineInput(creatingItem.type, null, tree, 0);
    }
  }
  
  function renderInlineInput(type: 'file' | 'folder', parentId: string | null, container: HTMLElement, explicitLevel: number = 0) {
    let parentLevel = explicitLevel;

    const wrapper = document.createElement('div');
    wrapper.className = 'flex items-center gap-1.5 px-2 py-[5px]';
    wrapper.style.paddingLeft = `${parentLevel * 12 + 8}px`;
    
    const icon = document.createElement('span');
    icon.className = 'flex items-center justify-center shrink-0 w-[14px] h-[14px]';
    icon.innerHTML = getFileIcon('', type);
    
    const input = document.createElement('input');
    input.type = 'text';
    input.className = 'flex-1 bg-transparent border border-[#007acc] text-[13px] outline-none text-white px-1';
    input.placeholder = type === 'folder' ? 'Folder name' : 'File name';
    
    input.addEventListener('input', () => {
      icon.innerHTML = getFileIcon(input.value.trim(), type);
    });

    wrapper.appendChild(icon);
    wrapper.appendChild(input);
    
    container.appendChild(wrapper);
    input.focus();
    
    let committed = false;
    const commit = () => {
      if (committed) return;
      committed = true;
      const name = input.value.trim();
      if (name) {
        if (vfs.some(n => n.name === name && n.parentId === parentId)) {
          showEditorToast(`A ${type} named "${name}" already exists in this folder.`, true);
          creatingItem = null;
          renderVFS();
          return;
        }
        if (type === 'file') {
          const newFile: VfsNode = {
            id: 'f-' + Date.now(),
            name,
            type: 'file',
            content: '// ' + name + '\n',
            parentId
          };
          vfs.push(newFile);
          saveVFS();
          creatingItem = null;
          openFile(newFile.id);
        } else {
          const newFolder: VfsNode = {
            id: 'd-' + Date.now(),
            name,
            type: 'folder',
            parentId
          };
          vfs.push(newFolder);
          activeFolderId = newFolder.id;
          creatingItem = null;
          saveVFS();
          renderVFS();
        }
      } else {
        creatingItem = null;
        renderVFS();
      }
    };
    
    input.onkeydown = (e) => {
      if (e.key === 'Enter') commit();
      if (e.key === 'Escape') {
        creatingItem = null;
        renderVFS();
      }
    };
    
    input.onblur = commit;
  }
  
  function openFile(id: string | null) {
    if (!id) {
      activeFileId = null;
      if (editorInstance) editorInstance.setValue('');
      document.getElementById('editor-breadcrumb')?.classList.add('hidden');
      renderTabs();
      renderVFS();
      return;
    }

    const file = vfs.find(n => n.id === id);
    if (!file || file.type !== 'file') return;
    activeFileId = id;
    
    if (!openTabIds.includes(id)) {
      openTabIds.push(id);
    }
    
    document.getElementById('editor-breadcrumb')?.classList.remove('hidden');

    const label = document.getElementById('editor-title-label');
    if (label) label.textContent = file.name;
    
    const icon = document.getElementById('editor-title-icon');
    if (icon) icon.innerHTML = getFileIcon(file.name, 'file');
    
    const breadcrumb = document.getElementById('breadcrumb-label');
    if (breadcrumb) breadcrumb.textContent = file.name;
    
    if (editorInstance) {
      editorInstance.setValue(file.content || '');
      
      let lang = 'javascript';
      if (file.name.endsWith('.ts') || file.name.endsWith('.tsx')) lang = 'typescript';
      else if (file.name.endsWith('.html')) lang = 'html';
      else if (file.name.endsWith('.css')) lang = 'css';
      else if (file.name.endsWith('.json')) lang = 'json';
      
      const model = editorInstance.getModel();
      if (model) {
        monaco.editor.setModelLanguage(model, lang);
      }
    }
    renderTabs();
    renderVFS();
  }
  
  function renderTabs() {
    const container = document.getElementById('editor-tabs-container');
    if (!container) return;
    container.innerHTML = '';
    
    openTabIds.forEach(tabId => {
      const file = vfs.find(n => n.id === tabId);
      if (!file) return;
      
      const isActive = tabId === activeFileId;
      
      const tab = document.createElement('div');
      tab.className = `flex items-center gap-2 px-4 h-full text-[12px] shrink-0 select-none relative cursor-pointer group transition-colors`;
      tab.style.borderRight = '1px solid var(--vscode-border)';
      tab.style.borderTop = `1px solid ${isActive ? 'var(--vscode-accent)' : 'transparent'}`;
      tab.style.background = isActive ? 'var(--vscode-editor)' : 'var(--vscode-sidebar)';
      tab.style.color = isActive ? 'var(--vscode-text)' : 'var(--vscode-text-dim)';
      if (!isActive) tab.onmouseenter = () => tab.style.background = 'rgba(255,255,255,0.05)';
      if (!isActive) tab.onmouseleave = () => tab.style.background = 'var(--vscode-sidebar)';
      
      const icon = document.createElement('span');
      icon.className = 'flex items-center';
      icon.innerHTML = getFileIcon(file.name, 'file');
      
      const label = document.createElement('span');
      label.className = 'leading-none';
      label.textContent = file.name;
      
      const closeBtn = document.createElement('button');
      closeBtn.className = `opacity-0 group-hover:opacity-100 hover:bg-white/10 transition-all border-none bg-transparent cursor-pointer p-[2px] ml-1 rounded flex items-center justify-center`;
      if (isActive) closeBtn.classList.remove('opacity-0');
      closeBtn.style.color = 'inherit';
      closeBtn.innerHTML = `<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>`;
      
      closeBtn.onclick = (e) => {
        e.stopPropagation();
        closeTab(tabId);
      };
      
      tab.onclick = () => {
        if (tabId !== activeFileId) openFile(tabId);
      };
      
      tab.appendChild(icon);
      tab.appendChild(label);
      tab.appendChild(closeBtn);
      container.appendChild(tab);
    });
  }

  function closeTab(id: string) {
    const idx = openTabIds.indexOf(id);
    if (idx === -1) return;
    openTabIds.splice(idx, 1);
    
    if (activeFileId === id) {
      if (openTabIds.length > 0) {
        const nextId = openTabIds[Math.min(idx, openTabIds.length - 1)];
        openFile(nextId);
      } else {
        openFile(null);
      }
    } else {
      renderTabs();
    }
  }
  
  function deleteNode(id: string) {
    const deleteRecursively = (targetId: string) => {
      const idx = openTabIds.indexOf(targetId);
      if (idx !== -1) openTabIds.splice(idx, 1);
      
      const children = vfs.filter(n => n.parentId === targetId);
      children.forEach(c => deleteRecursively(c.id));
      vfs = vfs.filter(n => n.id !== targetId);
    };
    deleteRecursively(id);
    
    if (activeFileId === id || !vfs.find(n => n.id === activeFileId)) {
      if (openTabIds.length > 0) openFile(openTabIds[0]);
      else openFile(null);
    } else {
      renderTabs();
    }
    if (activeFolderId === id) activeFolderId = null;
    
    saveVFS();
    renderVFS();
    showToast('✓ Deleted item');
  }

