---
import MenuBar from './MenuBar.astro';
import Sidebar from './Sidebar.astro';
import Editor from './Editor.astro';
import Console from './Console.astro';
import AIChat from './AIChat.astro';
---

<!-- VS Code-style app shell: ActivityBar | Sidebar | Editor+Panel | StatusBar -->
<div class="flex flex-col h-screen w-screen overflow-hidden" style="background:var(--vscode-bg)">

  <!-- ── Title Bar (Menu row) ── -->
  <MenuBar />

  <!-- ── Body (ActivityBar + Sidebar + Editor + Panel) ── -->
  <div class="flex flex-1 min-h-0">

    <!-- Activity Bar (left icon strip) -->
    <div class="flex flex-col items-center py-1 shrink-0" style="width:var(--activitybar-width);background:var(--vscode-activitybar);border-right:1px solid var(--vscode-border);">
      <!-- Sidebar toggle -->
      <button id="btn-toggle-sidebar" title="Toggle Sidebar"
        class="w-10 h-10 flex items-center justify-center mb-1 rounded cursor-pointer border-none transition-colors hover:bg-white/10"
        style="color:var(--vscode-text-dim);background:transparent;">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <rect x="3" y="3" width="18" height="18" rx="1"/><path d="M9 3v18"/>
        </svg>
      </button>
      <!-- Explorer -->
      <button class="activity-btn w-10 h-10 flex items-center justify-center rounded cursor-pointer border-none transition-colors hover:bg-white/10 mb-0.5 active-activity"
        style="color:var(--vscode-text-dim);background:transparent;" data-activity="explorer" title="Explorer">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1-2.5-2.5Z"/><path d="M8 7h8M8 11h5"/></svg>
      </button>
      <!-- History -->
      <button class="activity-btn w-10 h-10 flex items-center justify-center rounded cursor-pointer border-none transition-colors hover:bg-white/10 mb-0.5"
        style="color:var(--vscode-text-dim);background:transparent;" data-activity="history" title="History">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3.5 3.5"/></svg>
      </button>
      <!-- AI Chat button -->
      <button class="activity-btn w-10 h-10 flex items-center justify-center rounded cursor-pointer border-none transition-colors hover:bg-white/10"
        style="color:var(--vscode-text-dim);background:transparent;" data-activity="ai" title="AI Assistant" id="btn-ai-chat">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>
        </svg>
      </button>
      <!-- Settings (pushed to bottom) -->
      <div class="flex-1"/>
      <button class="activity-btn w-10 h-10 flex items-center justify-center rounded cursor-pointer border-none transition-colors hover:bg-white/10"
        style="color:var(--vscode-text-dim);background:transparent;" data-activity="settings" title="Settings">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
      </button>
    </div>

    <!-- Sidebar (file explorer style) -->
    <Sidebar />
    
    <!-- Sidebar Resizer -->
    <div id="sidebar-resizer" class="w-[4px] cursor-col-resize hover:bg-[var(--vscode-accent)] transition-colors z-10 -ml-[2px] relative" style="background: transparent;"></div>

    <!-- Main editor + panel area -->
    <div class="flex-1 flex flex-col min-w-0 min-h-0">
      <Editor />
      
      <!-- Terminal Resizer -->
      <div id="terminal-resizer" class="h-[4px] cursor-row-resize hover:bg-[var(--vscode-accent)] transition-colors z-10 -mt-[2px] relative" style="background: transparent;"></div>
      
      <Console />
    </div>

    <!-- AI Chat Resizer -->
    <div id="ai-chat-resizer" class="w-[4px] cursor-col-resize hover:bg-[var(--vscode-accent)] transition-colors z-10 relative" style="background:transparent;"></div>

    <!-- AI Chat Panel -->
    <AIChat />
  </div>

  <!-- ── Status Bar ── -->
  <div class="flex items-center h-[var(--statusbar-height)] shrink-0 px-2 gap-3 text-[11px] text-white" style="background:var(--vscode-statusbar);">
    <!-- Left status items -->
    <span class="flex items-center gap-1 opacity-90">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
      VSCompiler JS Compiler
    </span>
    <span class="opacity-70">|</span>
    <span id="exec-engine-badge" class="flex items-center gap-1 opacity-90">
      <span id="exec-engine-icon">🌐</span>
      <span id="exec-engine-label">Browser</span>
    </span>
    <span class="opacity-70">|</span>
    <span id="compiler-stats" class="flex items-center gap-1 opacity-90">
      <span id="compiler-status-indicator">Ready</span>
      <span id="compiler-time-val" class="opacity-70"></span>
    </span>

    <!-- Spacer -->
    <div class="flex-1"/>

    <!-- Right status items -->
    <span id="editor-cursor-pos" class="opacity-90">Ln 1, Col 1</span>
    <span class="opacity-70">|</span>
    <span class="opacity-90">JavaScript</span>
    <span class="opacity-70">|</span>
    <span class="opacity-90">UTF-8</span>
  </div>
</div>

<!-- Toast notification -->
<div id="toast-notification"
  class="fixed bottom-8 right-6 flex items-center gap-2.5 px-4 py-2.5 rounded text-[13px] font-medium z-[200] shadow-lg transition-all duration-300 translate-y-[80px] opacity-0"
  style="background:var(--vscode-sidebar);border:1px solid var(--vscode-border);color:var(--vscode-text);">
  <span class="text-[16px]">✓</span>
  <span id="toast-message">Done!</span>
</div>

<style>
  .activity-btn.active-activity {
    color: var(--vscode-text) !important;
    border-left: 2px solid var(--vscode-accent) !important;
    background: rgba(255,255,255,0.05) !important;
  }
  /* Sidebar collapsed */
  #app-sidebar.sidebar-collapsed {
    width: 0 !important;
    overflow: hidden;
  }
</style>

<script is:inline src="https://unpkg.com/prettier@2.8.8/standalone.js"></script>
<script is:inline src="https://unpkg.com/prettier@2.8.8/parser-babel.js"></script>
<script is:inline src="https://unpkg.com/@babel/standalone/babel.min.js"></script>

<!-- Monaco Editor from CDN — avoids bundling ~50MB of source through Vite (prevents OOM during build) -->
<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/monaco-editor/0.52.2/min/vs/loader.min.js"></script>
<script is:inline>
  // Configure the AMD loader path.
  // Layout.astro already created window._monacoReady as a deferred promise;
  // we just resolve it here once the engine is fully loaded.
  require.config({
    paths: { vs: 'https://cdnjs.cloudflare.com/ajax/libs/monaco-editor/0.52.2/min/vs' }
  });
  require(['vs/editor/editor.main'], function(m) {
    window.monaco = m;
    if (typeof window._resolveMonaco === 'function') window._resolveMonaco(m);
  });
</script>

<script>
  import { store } from '../lib/store';
  import { initVFS } from '../lib/vfs';

  // Initialize VFS
  initVFS();

  // Resize handling
  let isResizingSidebar = false;
  let isResizingTerminal = false;

  const sidebarResizer = document.getElementById('sidebar-resizer');
  const terminalResizer = document.getElementById('terminal-resizer');

  sidebarResizer?.addEventListener('mousedown', (e) => {
    isResizingSidebar = true;
    document.body.style.cursor = 'col-resize';
  });

  terminalResizer?.addEventListener('mousedown', (e) => {
    isResizingTerminal = true;
    document.body.style.cursor = 'row-resize';
  });

  document.addEventListener('mousemove', (e) => {
    if (isResizingSidebar) {
      const newWidth = Math.max(150, Math.min(e.clientX - 40, 600)); // 40 is ActivityBar width
      document.documentElement.style.setProperty('--sidebar-width', `${newWidth}px`);
      if (store.editorInstance) store.editorInstance.layout();
    }
    if (isResizingTerminal) {
      const windowHeight = window.innerHeight;
      const headerHeight = 35;
      const statusHeight = 22;
      const newHeight = Math.max(100, Math.min(windowHeight - e.clientY - statusHeight, windowHeight - headerHeight - statusHeight - 100));
      const consoleEl = document.getElementById('app-console');
      if (consoleEl) {
        consoleEl.style.flex = 'none';
        consoleEl.style.height = `${newHeight}px`;
        if (store.editorInstance) store.editorInstance.layout();
      }
    }
  });

  document.addEventListener('mouseup', () => {
    if (isResizingSidebar || isResizingTerminal) {
      isResizingSidebar = false;
      isResizingTerminal = false;
      document.body.style.cursor = 'default';
    }
  });

  // Activity Bar interactions
  document.querySelectorAll('.activity-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const activity = btn.getAttribute('data-activity');

      // AI Chat toggle
      if (activity === 'ai') {
        const isOpen = (window as any).isAIChatOpen?.();
        if (isOpen) {
          (window as any).closeAIChat?.();
          btn.classList.remove('active-activity');
        } else {
          document.querySelectorAll('.activity-btn').forEach(b => b.classList.remove('active-activity'));
          btn.classList.add('active-activity');
          (window as any).openAIChat?.();
        }
        return;
      }

      document.querySelectorAll('.activity-btn').forEach(b => b.classList.remove('active-activity'));
      btn.classList.add('active-activity');

      const sidebar = document.getElementById('app-sidebar');
      if (sidebar && sidebar.classList.contains('sidebar-collapsed')) {
        sidebar.classList.remove('sidebar-collapsed');
      }

      const tabBtn = document.querySelector(`.sidebar-tab-btn[data-tab="${activity}"]`) as HTMLElement;
      if (tabBtn) tabBtn.click();
    });
  });

  document.getElementById('btn-toggle-sidebar')?.addEventListener('click', () => {
    const sidebar = document.getElementById('app-sidebar');
    if (sidebar) {
      sidebar.classList.toggle('sidebar-collapsed');
      setTimeout(() => { if (store.editorInstance) store.editorInstance.layout(); }, 200);
    }
  });

  // Backend Engine Badge updates
  store.on('backend-status-changed', () => {
    const badge = document.getElementById('exec-engine-badge');
    const icon = document.getElementById('exec-engine-icon');
    const label = document.getElementById('exec-engine-label');
    if (badge && icon && label) {
      if (store.backendAvailable) {
        icon.textContent = '🐳';
        label.textContent = 'Container';
        badge.style.color = '#4ec9b0';
      } else {
        icon.textContent = '🌐';
        label.textContent = 'Browser';
        badge.style.color = '';
      }
    }
  });
</script>
