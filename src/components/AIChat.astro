---
import ChatHeader from './chat/ChatHeader.astro';
import ChatContextBar from './chat/ChatContextBar.astro';
import ChatWelcome from './chat/ChatWelcome.astro';
import ChatInputArea from './chat/ChatInputArea.astro';

// AIChat — Antigravity-style AI Assistant panel, powered by OpenRouter
const OPENROUTER_KEY   = import.meta.env.PUBLIC_OPENROUTER_API_KEY ?? '';
const NEMOTRON_KEY     = import.meta.env.NVIDIA_NEMOTRON_3_NANO ?? OPENROUTER_KEY;
---

<div id="ai-chat-panel"
  class="ai-chat-panel flex flex-col shrink-0 transition-all duration-300 overflow-hidden"
  style="width:0;background:#14151c;border-left:1px solid #2c2f42;">

  <ChatHeader />
  <ChatContextBar />

  <!-- ── Message history ── -->
  <div id="ai-chat-history" class="flex-1 overflow-y-auto px-3.5 py-4 flex flex-col gap-4">
    <ChatWelcome />
  </div>

  <ChatInputArea />
</div>

<style is:global>
  /* ── Panel open/close ── */
  #ai-chat-panel.ai-chat-open { width: 380px !important; }

  /* ── Dot animation ── */
  .ai-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    animation: ai-bounce 0.9s ease-in-out infinite;
  }
  @keyframes ai-bounce {
    0%, 80%, 100% { transform: scale(0.6); opacity: 0.4; }
    40%            { transform: scale(1.0); opacity: 1;   }
  }

  /* ── Toggle switch ── */
  .ai-toggle-cb { display: none; }
  .ai-toggle-track {
    display: inline-block; width: 24px; height: 13px;
    border-radius: 999px; background: #2c2f42;
    position: relative; transition: background 0.2s; flex-shrink: 0;
  }
  .ai-toggle-track::after {
    content: ''; position: absolute; top: 2px; left: 2px;
    width: 9px; height: 9px; border-radius: 50%;
    background: #6b7394; transition: transform 0.2s, background 0.2s;
  }
  .ai-toggle-cb:checked + .ai-toggle-track { background: rgba(157,124,242,0.5); }
  .ai-toggle-cb:checked + .ai-toggle-track::after {
    transform: translateX(11px); background: #9d7cf2;
  }

  /* ── Message rows (avatar layout) ── */
  .ai-msg {
    display: flex;
    flex-direction: row;
    gap: 10px;
    animation: ai-msg-in 0.2s ease-out;
  }
  .ai-msg-user { flex-direction: row-reverse; }
  @keyframes ai-msg-in {
    from { opacity: 0; transform: translateY(6px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* Avatar chip */
  .ai-msg-avatar {
    width: 26px; height: 26px; border-radius: 7px;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0; margin-top: 1px;
    border: 1px solid transparent;
  }
  .ai-msg-user .ai-msg-avatar {
    background: #1e2030;
    border-color: #2c2f42;
  }
  .ai-msg-assistant .ai-msg-avatar {
    background: rgba(157,124,242,0.12);
    border-color: rgba(157,124,242,0.25);
  }

  /* Bubble column */
  .ai-msg-body {
    display: flex; flex-direction: column; gap: 6px; min-width: 0; flex: 1;
  }
  .ai-msg-user .ai-msg-body { align-items: flex-end; max-width: 85%; flex: none; }
  .ai-msg-assistant .ai-msg-body { align-items: flex-start; width: 100%; }

  /* Bubble itself */
  .ai-msg-user .ai-bubble {
    background: #1f2335;
    border: 1px solid #2c2f42;
    border-radius: 14px 14px 4px 14px;
    box-shadow: 0 2px 12px rgba(0,0,0,0.3);
    padding: 10px 14px;
  }
  .ai-msg-assistant .ai-bubble {
    background: transparent;
    border: none;
    padding: 0;
    width: 100%;
  }
  .ai-bubble {
    font-size: 13px; line-height: 1.7;
    color: #c0caf5; word-break: break-word;
  }

  /* ── Inline code ── */
  .ai-bubble code:not(pre code) {
    font-family: 'JetBrains Mono', 'Cascadia Code', Consolas, monospace;
    font-size: 11px;
    background: rgba(157,124,242,0.18);
    color: #c4b5fd;
    padding: 1px 5px;
    border-radius: 4px;
    border: 1px solid rgba(157,124,242,0.25);
  }

  /* ── Code block wrapper ── */
  .ai-code-block {
    margin: 8px 0;
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid rgba(44,47,66,0.8);
    background: #0d1117;
    box-shadow: 0 4px 20px rgba(0,0,0,0.5);
    width: 100%;
  }

  .ai-code-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 7px 14px;
    background: rgba(255,255,255,0.04);
    border-bottom: 1px solid rgba(255,255,255,0.06);
    user-select: none;
    min-height: 32px;
  }
  .ai-code-lang-badge {
    font-family: 'JetBrains Mono', Consolas, monospace;
    font-size: 10.5px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #9d7cf2;
    display: flex;
    align-items: center;
    gap: 6px;
    flex-shrink: 0;
  }
  .ai-code-lang-badge::before {
    content: '';
    display: inline-block;
    width: 7px; height: 7px;
    border-radius: 50%;
    background: currentColor;
    opacity: 0.85;
    flex-shrink: 0;
  }
  .ai-copy-btn {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 10px;
    font-family: inherit;
    color: rgba(255,255,255,0.4);
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 3px 8px;
    border-radius: 4px;
    transition: color 0.15s, background 0.15s;
    font-weight: 500;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .ai-copy-btn svg { flex-shrink: 0; }
  .ai-copy-btn:hover {
    color: #9d7cf2;
    background: rgba(157,124,242,0.12);
  }
  .ai-copy-btn.copied {
    color: #9ece6a !important;
    background: rgba(158,206,106,0.1);
  }

  /* ── Code with line numbers (gutter via padding, not counter on flex) ── */
  .ai-code-block pre {
    margin: 0;
    padding: 12px 0;
    overflow-x: auto;
    font-family: 'JetBrains Mono', 'Cascadia Code', Consolas, monospace;
    font-size: 12px;
    line-height: 1.75;
    color: #c0caf5;
    background: transparent;
    border: none;
    border-radius: 0;
    tab-size: 2;
  }
  .ai-code-block pre code {
    display: block;
    padding: 0 16px;
    background: transparent;
    border: none;
    color: inherit;
    font-size: inherit;
    border-radius: 0;
    width: 100%;
  }
  .ai-code-block pre code .line {
    display: block;
    padding-left: 8px;
  }

  /* ── Syntax token colours (VS Code–inspired) ── */
  .ai-code-block pre .tok-kw   { color: #c586c0; font-weight: 500; }
  .ai-code-block pre .tok-str  { color: #ce9178; }
  .ai-code-block pre .tok-num  { color: #b5cea8; }
  .ai-code-block pre .tok-cmt  { color: #6a9955; font-style: italic; }
  .ai-code-block pre .tok-fn   { color: #dcdcaa; }
  .ai-code-block pre .tok-cls  { color: #4ec9b0; }
  .ai-code-block pre .tok-op   { color: #d4d4d4; }
  .ai-code-block pre .tok-var  { color: #9cdcfe; }
  .ai-code-block pre .tok-prop { color: #9cdcfe; }
  .ai-code-block pre .tok-type { color: #4ec9b0; }
  .ai-code-block pre .tok-mod  { color: #c586c0; }

  /* ── Markdown typography inside bubbles ── */
  .ai-bubble h1,.ai-bubble h2,.ai-bubble h3 {
    font-weight: 700; margin: 10px 0 4px; line-height: 1.3;
    color: #c0caf5;
  }
  .ai-bubble h1 { font-size: 15px; border-bottom: 1px solid rgba(255,255,255,0.08); padding-bottom: 4px; }
  .ai-bubble h2 { font-size: 13.5px; }
  .ai-bubble h3 { font-size: 12.5px; color: #9d7cf2; }
  .ai-bubble p  { margin: 4px 0; }
  .ai-bubble ul, .ai-bubble ol { margin: 6px 0 6px 18px; padding: 0; }
  .ai-bubble li { margin: 3px 0; }
  .ai-bubble ul li { list-style: disc; }
  .ai-bubble ol li { list-style: decimal; }
  .ai-bubble strong { color: #c0caf5; font-weight: 700; }
  .ai-bubble em { color: #9d7cf2; font-style: italic; }
  .ai-bubble blockquote {
    margin: 6px 0; padding: 6px 12px;
    border-left: 3px solid #9d7cf2;
    background: rgba(157,124,242,0.10);
    border-radius: 0 6px 6px 0;
    color: rgba(192,202,245,0.7);
  }
  .ai-bubble hr {
    border: none; border-top: 1px solid rgba(255,255,255,0.08);
    margin: 10px 0;
  }
  .ai-bubble a { color: #7dcfff; text-decoration: underline; }

  .ai-msg-meta {
    font-size: 9.5px; opacity: 0.4; color: #6b7394; padding: 0 2px;
    letter-spacing: 0.01em;
  }
  .ai-msg-user .ai-msg-meta { text-align: right; }

  /* ── Diff (tool-call) card ── */
  .ai-diff-card {
    overflow: hidden; border-radius: 10px; border: 1px solid #262a3c;
    background: #1a1b26; width: 100%; margin: 6px 0;
  }
  .ai-diff-card-header {
    display: flex; align-items: center; gap: 8px;
    padding: 8px 12px; cursor: pointer; user-select: none;
    transition: background 0.15s;
  }
  .ai-diff-card-header:hover { background: rgba(255,255,255,0.03); }
  .ai-diff-card-summary { padding: 0 12px 8px; font-size: 11.5px; color: #6b7394; }
  .ai-diff-card-body { border-top: 1px solid #262a3c; }
  .ai-diff-row {
    display: flex; gap: 8px; padding: 1px 14px;
    font-family: 'JetBrains Mono','Cascadia Code',Consolas,monospace;
    font-size: 11.5px; line-height: 1.6;
  }
  .ai-diff-row.ai-diff-add    { color: #9ece6a; background: rgba(158,206,106,0.08); }
  .ai-diff-row.ai-diff-remove { color: #f7768e; background: rgba(247,118,142,0.08); }
  .ai-diff-row.ai-diff-ctx    { color: #6b7394; }
  .ai-diff-row .ai-diff-pfx   { width: 12px; display: inline-block; flex-shrink: 0; }
  .ai-diff-chevron { transition: transform 0.2s; }
  .ai-diff-chevron.open { transform: rotate(180deg); }

  /* Scrollbar for code blocks */
  .ai-code-block pre::-webkit-scrollbar { height: 4px; }
  .ai-code-block pre::-webkit-scrollbar-track { background: transparent; }
  .ai-code-block pre::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.10); border-radius: 2px; }

  /* ── Streaming cursor ── */
  .ai-streaming-cursor::after {
    content: '▌'; animation: ai-cursor-blink 0.7s step-end infinite; color: #9d7cf2;
    margin-left: 2px;
  }
  @keyframes ai-cursor-blink { 0%,100% { opacity: 1; } 50% { opacity: 0; } }

  /* ── Input focus ── */
  #ai-input-wrap:focus-within {
    border-color: rgba(157,124,242,0.6) !important;
    box-shadow: 0 0 0 2px rgba(157,124,242,0.15);
  }

  /* ── Quick prompt hover ── */
  .ai-quick-prompt:hover {
    background: rgba(157,124,242,0.12) !important;
    border-color: rgba(157,124,242,0.4) !important;
    color: #c0caf5 !important;
  }

  /* ── Model dropdown ── */
  .ai-model-item {
    display: flex; align-items: center; gap: 8px;
    padding: 7px 12px; font-size: 11px; cursor: pointer;
    transition: background 0.1s; color: #c0caf5;
  }
  .ai-model-item:hover { background: rgba(255,255,255,0.07); }
  .ai-model-item.selected { color: #9d7cf2; }
  .ai-model-item .ai-model-provider {
    font-size: 9px; opacity: 0.5; margin-left: auto;
  }

  /* ── Mode tabs ── */
  .ai-mode-tab:hover { background: #1f2335 !important; color: #c0caf5 !important; }

  /* ── Scrollbar ── */
  #ai-chat-history::-webkit-scrollbar { width: 4px; }
  #ai-chat-history::-webkit-scrollbar-track { background: transparent; }
  #ai-chat-history::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.08); border-radius: 2px; }

  /* ── Plan & tool cards ── */
  .ai-plan-card {
    overflow: hidden; border-radius: 10px; border: 1px solid #262a3c;
    background: #1a1b26; width: 100%; margin: 8px 0;
  }
  .ai-plan-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 8px 12px; cursor: pointer; user-select: none;
  }
  .ai-plan-header:hover { background: rgba(255,255,255,0.03); }
  .ai-plan-steps { padding: 0 12px 12px; display: flex; flex-direction: column; gap: 6px; }
  .ai-plan-step {
    display: flex; align-items: center; gap: 8px; font-size: 12px;
    color: #c0caf5;
  }
  .ai-plan-step .status-done { color: #9ece6a; }
  .ai-plan-step .status-active { color: #e0af68; animation: spin 1s linear infinite; }
  .ai-plan-step .status-pending { color: #4b5066; }
  .ai-plan-step .label-pending { color: #4b5066; }

  .ai-tool-card {
    overflow: hidden; border-radius: 10px; border: 1px solid #262a3c;
    background: #1a1b26; width: 100%; margin: 8px 0;
  }
  .ai-tool-header {
    display: flex; align-items: center; gap: 8px;
    padding: 8px 12px; cursor: pointer; user-select: none;
  }
  .ai-tool-header:hover { background: rgba(255,255,255,0.03); }
  .ai-tool-summary { padding: 0 12px 8px; font-size: 12px; color: #6b7394; }
  .ai-tool-diff {
    border-top: 1px solid #262a3c; padding: 4px 0;
  }
  .ai-diff-line {
    display: flex; gap: 8px; padding: 1px 12px; font-family: monospace; font-size: 12px; line-height: 1.6;
  }
  .ai-diff-line.context { color: #6b7394; }
  .ai-diff-line.add { color: #9ece6a; background: rgba(158,206,106,0.08); }
  .ai-diff-line.remove { color: #f7768e; background: rgba(247,118,142,0.08); }
  .ai-diff-line .prefix { width: 12px; display: inline-block; }

  .ai-terminal-card {
    overflow: hidden; border-radius: 10px; border: 1px solid #262a3c;
    background: #1a1b26; width: 100%; margin: 8px 0;
  }
  .ai-terminal-header {
    display: flex; align-items: center; gap: 8px;
    padding: 8px 12px; border-bottom: 1px solid #262a3c;
  }
  .ai-terminal-body {
    padding: 10px 12px; font-family: monospace; font-size: 12px; line-height: 1.6;
    color: #c0caf5; white-space: pre-wrap;
  }
  .ai-terminal-body .command { color: #7dcfff; }
  .ai-terminal-body .output { color: #6b7394; }

  @keyframes spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
</style>

<script define:vars={{ OPENROUTER_KEY, NEMOTRON_KEY }}>
  window.__OR_KEY       = OPENROUTER_KEY;
  window.__NEMOTRON_KEY = NEMOTRON_KEY;
</script>

<script>
  import { store } from '../lib/store';
  import { callOpenRouter } from '../lib/chat/api';
  import { markdownToHtml, escapeHtml } from '../lib/chat/markdown';
  import type { Model, ChatMessage } from '../lib/chat/types';

  // ── Models ────────────────────────────────────────────────────────────────
  const MODELS: Model[] = [
    {
      id:       'google/gemma-4-31b-it:free',
      label:    'Gemma 4 31B',
      icon:     '✦',
      provider: 'Google (free)',
      apiKey:   (window as any).__OR_KEY,
    },
    {
      id:       'nvidia/nemotron-3-nano-30b-a3b:free',
      label:    'Nemotron Nano',
      icon:     '🟢',
      provider: 'NVIDIA (free)',
      apiKey:   (window as any).__NEMOTRON_KEY,
    },
  ];

  // ── State ─────────────────────────────────────────────────────────────────
  let selectedModel = MODELS[0];
  let chatHistory: ChatMessage[] = [];
  let abortController: AbortController | null = null;
  let isStreaming = false;

  // ── DOM refs ──────────────────────────────────────────────────────────────
  const panel          = document.getElementById('ai-chat-panel')!;
  const historyEl      = document.getElementById('ai-chat-history')!;
  const welcome        = document.getElementById('ai-chat-welcome')!;
  const typingInd      = document.getElementById('ai-typing-indicator')!;
  const typingLabel    = document.getElementById('ai-typing-label')!;
  const chatInput      = document.getElementById('ai-chat-input') as HTMLTextAreaElement;
  const sendBtn        = document.getElementById('ai-send-btn')!;
  const sendIcon       = document.getElementById('ai-send-icon')!;
  const stopIcon       = document.getElementById('ai-stop-icon')!;
  const modelLabel     = document.getElementById('ai-model-label')!;
  const modelDropdown  = document.getElementById('ai-model-dropdown')!;
  const modelList      = document.getElementById('ai-model-list')!;
  const modelBtn       = document.getElementById('ai-model-selector-btn')!;
  const includeCode    = document.getElementById('ai-include-code') as HTMLInputElement;
  const ctxFilePill    = document.getElementById('ai-context-file-pill')!;
  const ctxFileName    = document.getElementById('ai-context-file-name')!;
  const apiStatus      = document.getElementById('ai-api-status')!;
  const statusDot      = document.getElementById('ai-status-dot')!;
  const statusLabel    = document.getElementById('ai-status-label')!;
  const thinkingDot    = document.getElementById('ai-thinking-dot')!;
  const idleDot        = document.getElementById('ai-idle-dot')!;

  const OR_KEY: string = (window as any).__OR_KEY || '';
  if (OR_KEY) {
    apiStatus.innerHTML = `<span style="color:#9ece6a;">●</span> <span>Connected</span>`;
  } else {
    apiStatus.innerHTML = `<span style="color:#f7768e;">●</span> <span>No API key</span>`;
  }

  // ── Status dot helper ─────────────────────────────────────────────────────
  function setStatus(thinking: boolean) {
    if (thinking) {
      thinkingDot.classList.remove('hidden');
      idleDot.style.background = '#e0af68';
      statusLabel.textContent = 'Working';
    } else {
      thinkingDot.classList.add('hidden');
      idleDot.style.background = '#9ece6a';
      statusLabel.textContent = 'Idle';
    }
  }
  setStatus(false);

  // ── Model dropdown ────────────────────────────────────────────────────────
  function buildModelList() {
    modelList.innerHTML = '';
    modelLabel.textContent = selectedModel.label;
    MODELS.forEach(m => {
      const item = document.createElement('div');
      item.className = 'ai-model-item' + (m.id === selectedModel.id ? ' selected' : '');
      item.innerHTML = `
        <span style="font-size:14px">${m.icon}</span>
        <span>${m.label}</span>
        <span class="ai-model-provider">${m.provider}</span>
        ${m.id === selectedModel.id
          ? `<svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#9d7cf2" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>`
          : ''}
      `;
      item.onclick = () => {
        selectedModel = m;
        modelLabel.textContent = m.label;
        modelDropdown.classList.add('hidden');
        buildModelList();
      };
      modelList.appendChild(item);
    });
  }
  buildModelList();

  modelBtn.addEventListener('click', e => {
    e.stopPropagation();
    modelDropdown.classList.toggle('hidden');
  });
  document.addEventListener('click', () => modelDropdown.classList.add('hidden'));

  // ── Mode tabs ─────────────────────────────────────────────────────────────
  document.querySelectorAll('.ai-mode-tab').forEach(tab => {
    tab.addEventListener('click', function() {
      document.querySelectorAll('.ai-mode-tab').forEach(t => {
        (t as HTMLElement).style.background = 'transparent';
        (t as HTMLElement).style.color = '#6b7394';
      });
      (this as HTMLElement).style.background = '#1f2335';
      (this as HTMLElement).style.color = '#7dcfff';
    });
  });

  // ── Context pill ──────────────────────────────────────────────────────────
  function updateContextPill() {
    if (store.activeFileId) {
      const file = store.vfs.find((n: any) => n.id === store.activeFileId);
      if (file) {
        ctxFileName.textContent = file.name;
        ctxFilePill.classList.remove('hidden');
        ctxFilePill.classList.add('flex');
        return;
      }
    }
    ctxFilePill.classList.add('hidden');
    ctxFilePill.classList.remove('flex');
  }
  store.on('active-file-changed', updateContextPill);
  updateContextPill();

  // ── Auto-resize textarea ──────────────────────────────────────────────────
  chatInput.addEventListener('input', () => {
    chatInput.style.height = 'auto';
    chatInput.style.height = Math.min(chatInput.scrollHeight, 120) + 'px';
  });

  // ── Keyboard ──────────────────────────────────────────────────────────────
  chatInput.addEventListener('keydown', e => {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      if (isStreaming) stopStreaming();
      else sendMessage();
    }
  });

  sendBtn.addEventListener('click', () => {
    if (isStreaming) stopStreaming();
    else sendMessage();
  });

  function stopStreaming() {
    abortController?.abort();
  }

  function setStreamingState(streaming: boolean) {
    isStreaming = streaming;
    setStatus(streaming);
    if (streaming) {
      sendIcon.classList.add('hidden');
      stopIcon.classList.remove('hidden');
      sendBtn.style.background = 'linear-gradient(135deg,#f7768e,#e0af68)';
      sendBtn.title = 'Stop (Enter)';
      typingInd.classList.remove('hidden');
    } else {
      sendIcon.classList.remove('hidden');
      stopIcon.classList.add('hidden');
      sendBtn.style.background = 'linear-gradient(135deg,#9d7cf2,#7dcfff)';
      sendBtn.title = 'Send (Enter)';
      typingInd.classList.add('hidden');
    }
    sendBtn.style.opacity = '1';
  }

  // ── Quick prompts ─────────────────────────────────────────────────────────
  document.querySelectorAll('.ai-quick-prompt').forEach(btn => {
    btn.addEventListener('click', () => {
      chatInput.value = btn.getAttribute('data-prompt') || '';
      chatInput.dispatchEvent(new Event('input'));
      sendMessage();
    });
  });

  // ── New chat ──────────────────────────────────────────────────────────────
  document.getElementById('ai-new-chat')?.addEventListener('click', () => {
    stopStreaming();
    chatHistory = [];
    renderMessages();
  });

  // ── Close ─────────────────────────────────────────────────────────────────
  document.getElementById('ai-chat-close')?.addEventListener('click', () => {
    panel.classList.remove('ai-chat-open');
    document.querySelector('.activity-btn[data-activity="ai"]')?.classList.remove('active-activity');
    if (store.editorInstance) store.editorInstance.layout();
  });

  // ── Helpers ───────────────────────────────────────────────────────────────
  function timestamp() {
    return new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
  }

  // ── Message rendering ─────────────────────────────────────────────────────
  function renderMessages() {
    historyEl.querySelectorAll('.ai-msg').forEach(el => el.remove());
    if (chatHistory.length === 0) {
      welcome.style.display = '';
      return;
    }
    welcome.style.display = 'none';
    chatHistory.forEach(msg => appendBubble(msg.role, msg.content, msg.ts, false));
    historyEl.scrollTop = historyEl.scrollHeight;
  }

  function appendBubble(
    role: 'user' | 'assistant',
    content: string,
    ts: string,
    animate = true,
    streaming = false
  ): HTMLElement {
    welcome.style.display = 'none';

    const wrapper = document.createElement('div');
    wrapper.className = `ai-msg ai-msg-${role}`;
    if (!animate) wrapper.style.animation = 'none';

    // ── Avatar chip ──────────────────────────────────────────────────────
    const avatar = document.createElement('div');
    avatar.className = 'ai-msg-avatar';
    if (role === 'user') {
      avatar.innerHTML = `<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#6b7394" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>`;
    } else {
      avatar.innerHTML = `<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#9d7cf2" stroke-width="2.5"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>`;
    }

    // ── Body column ──────────────────────────────────────────────────────
    const body = document.createElement('div');
    body.className = 'ai-msg-body';

    const bubble = document.createElement('div');
    bubble.className = 'ai-bubble' + (streaming ? ' ai-streaming-cursor' : '');
    bubble.innerHTML = role === 'assistant' ? markdownToHtml(content) : escapeHtml(content);

    const meta = document.createElement('div');
    meta.className = 'ai-msg-meta';
    meta.textContent = role === 'user' ? `You · ${ts}` : `${selectedModel.label} · ${ts}`;

    body.appendChild(bubble);
    body.appendChild(meta);
    wrapper.appendChild(avatar);
    wrapper.appendChild(body);
    historyEl.appendChild(wrapper);
    historyEl.scrollTop = historyEl.scrollHeight;
    return bubble;
  }

  // ── Send message ──────────────────────────────────────────────────────────
  async function sendMessage() {
    const text = chatInput.value.trim();
    if (!text || isStreaming) return;

    chatInput.value = '';
    chatInput.style.height = 'auto';

    const ts = timestamp();
    chatHistory.push({ role: 'user', content: text, ts });
    appendBubble('user', text, ts);

    setStreamingState(true);
    typingLabel.textContent = 'Thinking…';
    historyEl.scrollTop = historyEl.scrollHeight;

    let system = `You are an expert JavaScript/TypeScript coding assistant embedded in a VS Code-style online compiler. Be concise, helpful, and format code with markdown fenced code blocks. You may also include task plans using Markdown checklists (- [ ] task) and diff blocks using \`\`\`diff.`;
    if (includeCode.checked && (store as any).editorInstance) {
      const code = (store as any).editorInstance.getValue();
      const fileName = store.activeFileId
        ? (store.vfs.find((n: any) => n.id === store.activeFileId)?.name ?? 'untitled.js')
        : 'untitled.js';
      if (code.trim()) {
        system += `\n\nCurrent editor file (${fileName}):\n\`\`\`javascript\n${code}\n\`\`\``;
      }
    }

    const messages = [
      { role: 'system', content: system },
      ...chatHistory.slice(0, -1).map(m => ({ role: m.role, content: m.content })),
      { role: 'user', content: text }
    ];

    try {
      const activeKey = selectedModel.apiKey || OR_KEY;
      if (!activeKey) {
        throw new Error('No OpenRouter API key found. Add PUBLIC_OPENROUTER_API_KEY to your .env file.');
      }

      abortController = new AbortController();
      typingLabel.textContent = 'Generating…';

      const aiTs   = timestamp();
      const bubble = appendBubble('assistant', '', aiTs, true, true);

      await callOpenRouter({
        model: selectedModel,
        messages,
        apiKey: activeKey,
        signal: abortController.signal,
        onChunk: (textChunk) => {
          bubble.innerHTML = markdownToHtml(textChunk);
          bubble.classList.add('ai-streaming-cursor');
          historyEl.scrollTop = historyEl.scrollHeight;
        },
        onDone: (fullText) => {
          bubble.classList.remove('ai-streaming-cursor');
          bubble.innerHTML = markdownToHtml(fullText);
          chatHistory.push({ role: 'assistant', content: fullText, ts: aiTs });
          setStreamingState(false);
          abortController = null;
          chatInput.focus();
        },
        onError: (err) => {
          if (err.message === 'AbortError') {
            bubble.classList.remove('ai-streaming-cursor');
            chatHistory.push({ role: 'assistant', content: '(stopped)', ts: timestamp() });
          } else {
            const errTs  = timestamp();
            const errMsg = `⚠️ ${err.message || 'Could not reach OpenRouter. Please try again.'}`;
            chatHistory.push({ role: 'assistant', content: errMsg, ts: errTs });
            appendBubble('assistant', errMsg, errTs);
          }
          setStreamingState(false);
          abortController = null;
          chatInput.focus();
        }
      });
      
    } catch (err: any) {
      setStreamingState(false);
      abortController = null;
      chatInput.focus();
    }
  }

  // ── Open / close ──────────────────────────────────────────────────────────
  (window as any).openAIChat = () => {
    panel.classList.add('ai-chat-open');
    setTimeout(() => chatInput.focus(), 300);
    if ((store as any).editorInstance) (store as any).editorInstance.layout();
  };
  (window as any).closeAIChat = () => {
    panel.classList.remove('ai-chat-open');
    if ((store as any).editorInstance) (store as any).editorInstance.layout();
  };
  (window as any).isAIChatOpen = () => panel.classList.contains('ai-chat-open');

  // ── Copy code ─────────────────────────────────────────────────────────────
  (window as any).aiCopyCode = (btn: HTMLButtonElement) => {
    const blockId = btn.getAttribute('data-target');
    const block   = document.getElementById(blockId!);
    const lineElements = block?.querySelectorAll('pre code .line');
    let code = '';
    if (lineElements && lineElements.length > 0) {
      code = Array.from(lineElements).map(el => el.textContent).join('\n');
    } else {
      code = block?.querySelector('pre code')?.textContent ?? '';
    }
    navigator.clipboard.writeText(code).then(() => {
      btn.classList.add('copied');
      const prev = btn.innerHTML;
      btn.innerHTML = `<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>Copied`;
      setTimeout(() => {
        btn.classList.remove('copied');
        btn.innerHTML = prev;
      }, 2000);
    });
  };
</script>