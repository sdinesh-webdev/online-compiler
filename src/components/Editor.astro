---
// Editor Pane — VS Code tab bar + Monaco mount
---

<div class="flex flex-col flex-[1.4] min-h-0" style="background:var(--vscode-editor);">

  <!-- Tab Bar -->
  <div class="flex items-end shrink-0 overflow-x-auto" style="background:var(--vscode-sidebar);border-bottom:1px solid var(--vscode-border);height:var(--tabbar-height);">
    <!-- Tabs Container -->
    <div id="editor-tabs-container" class="flex items-end h-full overflow-x-auto no-scrollbar shrink-0">
      <!-- Tabs will be injected here -->
    </div>
    
    <!-- Tab Add Button -->
    <button id="tab-add-btn" class="flex items-center justify-center w-8 h-full opacity-50 hover:opacity-100 hover:bg-white/5 border-none bg-transparent cursor-pointer transition-all" style="color:var(--vscode-text)" title="New File">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
    </button>
    
    <!-- Breadcrumb after tabs -->
    <div id="editor-breadcrumb" class="flex items-center gap-1 px-4 text-[11px] h-full ml-auto opacity-50 shrink-0 hidden" style="color:var(--vscode-text-dim)">
      <span>workspace</span>
      <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
      <span id="breadcrumb-label" style="color:var(--vscode-text)"></span>
    </div>
  </div>

  <!-- Monaco Editor mount -->
  <div class="flex-1 relative overflow-hidden" id="editor-mount">
    <!-- Loading placeholder -->
    <div class="flex items-center justify-center h-full flex-col gap-3 opacity-50" style="color:var(--vscode-text-dim)">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="animate-spin">
        <path d="M21 12a9 9 0 1 1-6.219-8.56"/>
      </svg>
      <span class="text-[12px]">Initializing Monaco Editor...</span>
    </div>
  </div>
</div>

<script>
  import { store, type VfsNode } from '../lib/store';
  import { saveVFS, openFile, closeTab, getFileIcon, getTargetParentId } from '../lib/vfs';
  import { executeJS, probeBackend } from '../lib/engine';
  import { registerTailwindCompletions } from '../lib/tailwind-intellisense';
  import { renderHistory } from '../lib/console';

  // Render Tabs logic
  function renderTabs() {
    const container = document.getElementById('editor-tabs-container');
    if (!container) return;
    container.innerHTML = '';
    
    store.openTabIds.forEach(tabId => {
      const file = store.vfs.find((n: VfsNode) => n.id === tabId);
      if (!file) return;
      
      const isActive = tabId === store.activeFileId;
      
      const tab = document.createElement('div');
      tab.className = `flex items-center gap-2 px-4 h-full text-[12px] shrink-0 select-none relative cursor-pointer group transition-colors`;
      tab.style.borderRight = '1px solid var(--vscode-border)';
      tab.style.borderTop = `1px solid ${isActive ? 'var(--vscode-accent)' : 'transparent'}`;
      tab.style.background = isActive ? 'var(--vscode-editor)' : 'var(--vscode-sidebar)';
      tab.style.color = isActive ? 'var(--vscode-text)' : 'var(--vscode-text-dim)';
      if (!isActive) tab.onmouseenter = () => tab.style.background = 'rgba(255,255,255,0.05)';
      if (!isActive) tab.onmouseleave = () => tab.style.background = 'var(--vscode-sidebar)';
      
      const icon = document.createElement('span');
      icon.className = 'flex items-center';
      icon.innerHTML = getFileIcon(file.name, 'file');
      
      const label = document.createElement('span');
      label.className = 'leading-none';
      label.textContent = file.name;
      
      const closeBtn = document.createElement('button');
      closeBtn.className = `opacity-0 group-hover:opacity-100 hover:bg-white/10 transition-all border-none bg-transparent cursor-pointer p-[2px] ml-1 rounded flex items-center justify-center`;
      if (isActive) closeBtn.classList.remove('opacity-0');
      closeBtn.style.color = 'inherit';
      closeBtn.innerHTML = `<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>`;
      
      closeBtn.onclick = (e) => {
        e.stopPropagation();
        closeTab(tabId);
      };
      
      tab.onclick = () => {
        if (tabId !== store.activeFileId) openFile(tabId);
      };
      
      tab.appendChild(icon);
      tab.appendChild(label);
      tab.appendChild(closeBtn);
      container.appendChild(tab);
    });
  }

  store.on('tabs-changed', renderTabs);
  store.on('active-file-changed', renderTabs);

  document.getElementById('tab-add-btn')?.addEventListener('click', () => {
    store.setCreatingItem({ type: 'file', parentId: getTargetParentId() });
  });

  // Monaco Editor Initialization
  (async () => {
    await (window as any)._monacoReady;
    const monaco = (window as any).monaco;
    registerTailwindCompletions(monaco);

    const mount = document.getElementById('editor-mount')!;
    mount.innerHTML = '';

    monaco.editor.defineTheme('cyberpunk', {
      base: 'vs-dark', inherit: true,
      rules: [
        { token: 'comment', foreground: 'bd00ff', fontStyle: 'italic' },
        { token: 'keyword', foreground: 'ff007f', fontStyle: 'bold' },
        { token: 'number', foreground: '00ffff' },
        { token: 'string', foreground: '00ffff' },
      ],
      colors: {
        'editor.background': '#0c0813',
        'editor.foreground': '#00ffff',
        'editor.lineHighlightBackground': '#1a0826',
        'editorLineNumber.foreground': '#ff007f',
      }
    });

    const compilerOptions = {
      target: monaco.languages.typescript.ScriptTarget.ESNext,
      allowNonTsExtensions: true,
      jsx: monaco.languages.typescript.JsxEmit.React,
      moduleResolution: monaco.languages.typescript.ModuleResolutionKind.NodeJs,
      module: monaco.languages.typescript.ModuleKind.CommonJS,
      noEmit: true,
      allowJs: true,
      typeRoots: ["node_modules/@types"]
    };
    monaco.languages.typescript.javascriptDefaults.setCompilerOptions(compilerOptions);
    monaco.languages.typescript.typescriptDefaults.setCompilerOptions(compilerOptions);
    
    monaco.languages.typescript.javascriptDefaults.setDiagnosticsOptions({
      noSemanticValidation: true,
      noSyntaxValidation: false
    });

    let initialCode = '// Write your JavaScript here\\nconsole.log("Hello, world!");\\n';
    const initialHash = window.location.hash;
    if (initialHash.startsWith('#code=')) {
      try { initialCode = atob(initialHash.substring(6)); } catch (_) {}
    }

    store.editorInstance = monaco.editor.create(mount, {
      value: initialCode,
      language: 'javascript',
      theme: 'vs-dark',
      fontSize: 14,
      fontFamily: "'JetBrains Mono', 'Cascadia Code', Consolas, monospace",
      fontLigatures: true,
      automaticLayout: true,
      minimap: { enabled: true, scale: 1 },
      lineNumbers: 'on',
      wordWrap: 'on',
      cursorBlinking: 'smooth',
      cursorSmoothCaretAnimation: 'on',
      tabSize: 2,
      padding: { top: 8, bottom: 8 },
      scrollBeyondLastLine: false,
      renderLineHighlight: 'all',
      bracketPairColorization: { enabled: true },
      smoothScrolling: true,
      autoClosingBrackets: 'always',
      autoClosingQuotes: 'always',
      autoClosingOvertype: 'always',
      autoClosingDelete: 'always',
      formatOnType: true,
      formatOnPaste: true,
    });

    store.editorInstance.onDidChangeCursorPosition((e: any) => {
      const el = document.getElementById('editor-cursor-pos');
      if (el) el.textContent = `Ln ${e.position.lineNumber}, Col ${e.position.column}`;
    });

    store.editorInstance.addCommand(
      monaco.KeyMod.CtrlCmd | monaco.KeyCode.Enter,
      () => executeJS()
    );
    
    store.editorInstance.addCommand(
      monaco.KeyMod.CtrlCmd | monaco.KeyCode.KeyS,
      () => {
        if (store.activeFileId) {
          const file = store.vfs.find((n: VfsNode) => n.id === store.activeFileId);
          if (file) {
            file.content = store.editorInstance.getValue();
            saveVFS();
            const { showToast } = require('../lib/vfs');
            showToast('✓ Saved ' + file.name);
          }
        }
      }
    );

    let debounceTimeout: any = null;
    store.editorInstance.onDidChangeModelContent((e: any) => {
      if (store.activeFileId) {
         const file = store.vfs.find((n: VfsNode) => n.id === store.activeFileId);
         if (file) {
            file.content = store.editorInstance.getValue();
            saveVFS();
         }
      }
      
      const changes = e.changes[0];
      if (changes && changes.text === '>') {
        const pos = store.editorInstance.getPosition();
        if (pos) {
          const line = store.editorInstance.getModel().getLineContent(pos.lineNumber);
          const textBeforeCursor = line.substring(0, pos.column - 1);
          const match = textBeforeCursor.match(/<([a-zA-Z0-9_-]+)[^>]*>$/);
          if (match && !textBeforeCursor.endsWith('/' + '>')) {
            const tag = match[1];
            const voidElements = ['area', 'base', 'br', 'col', 'embed', 'hr', 'img', 'input', 'link', 'meta', 'param', 'source', 'track', 'wbr'];
            if (!voidElements.includes(tag.toLowerCase())) {
              const closingTag = `</${tag}>`;
              setTimeout(() => {
                store.editorInstance.executeEdits('auto-close-tag', [{
                  range: new monaco.Range(pos.lineNumber, pos.column, pos.lineNumber, pos.column),
                  text: closingTag,
                  forceMoveMarkers: true
                }]);
                store.editorInstance.setPosition({ lineNumber: pos.lineNumber, column: pos.column });
              }, 0);
            }
          }
        }
      }

      const mode = (document.getElementById('setting-autorun') as HTMLSelectElement)?.value;
      if (mode === 'debounce') {
        clearTimeout(debounceTimeout);
        debounceTimeout = setTimeout(() => executeJS(), 1000);
      }
    });

    // We can call initVFS from Compiler.astro, but since Monaco is async,
    // we should emit an event or just do it here to ensure Monaco exists before opening file.
    store.emit('monaco-ready');

    renderHistory();
    probeBackend();

    const mode = (document.getElementById('setting-autorun') as HTMLSelectElement)?.value;
    if (mode === 'debounce') {
      setTimeout(() => executeJS(), 500);
    }
  })();

  document.getElementById('setting-fontsize')?.addEventListener('change', e => {
    store.editorInstance?.updateOptions({ fontSize: parseInt((e.target as HTMLSelectElement).value) });
  });
  document.getElementById('setting-tabsize')?.addEventListener('change', e => {
    store.editorInstance?.updateOptions({ tabSize: parseInt((e.target as HTMLSelectElement).value) });
  });
  document.getElementById('setting-wrap')?.addEventListener('change', e => {
    store.editorInstance?.updateOptions({ wordWrap: (e.target as HTMLSelectElement).value });
  });
  document.getElementById('setting-theme')?.addEventListener('change', e => {
    const val = (e.target as HTMLSelectElement).value;
    document.documentElement.setAttribute('data-theme', val);
    document.body.setAttribute('data-theme', val);
    if (!store.editorInstance) return;
    const monacoTheme = val === 'light' ? 'vs' : val === 'cyberpunk' ? 'cyberpunk' : 'vs-dark';
    (window as any).monaco.editor.setTheme(monacoTheme);
  });
</script>
