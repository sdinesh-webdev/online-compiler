---
// Editor Pane — VS Code tab bar + Monaco mount
---

<div class="flex flex-col flex-[1.4] min-h-0" style="background:var(--vscode-editor);">

  <!-- Tab Bar -->
  <div class="flex items-end shrink-0 overflow-x-auto" style="background:var(--vscode-sidebar);border-bottom:1px solid var(--vscode-border);height:var(--tabbar-height);">
    <!-- Tabs Container -->
    <div id="editor-tabs-container" class="flex items-end h-full overflow-x-auto no-scrollbar shrink-0">
      <!-- Tabs will be injected here -->
    </div>
    
    <!-- Tab Add Button -->
    <button id="tab-add-btn" class="flex items-center justify-center w-8 h-full opacity-50 hover:opacity-100 hover:bg-white/5 border-none bg-transparent cursor-pointer transition-all" style="color:var(--vscode-text)" title="New File">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
    </button>
    
    <!-- Breadcrumb after tabs -->
    <div id="editor-breadcrumb" class="flex items-center gap-1 px-4 text-[11px] h-full ml-auto opacity-50 shrink-0 hidden" style="color:var(--vscode-text-dim)">
      <span>workspace</span>
      <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
      <span id="breadcrumb-label" style="color:var(--vscode-text)"></span>
    </div>
  </div>

  <!-- Monaco Editor mount -->
  <div class="flex-1 relative overflow-hidden" id="editor-mount">
    <!-- Loading placeholder -->
    <div class="flex items-center justify-center h-full flex-col gap-3 opacity-50" style="color:var(--vscode-text-dim)">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="animate-spin">
        <path d="M21 12a9 9 0 1 1-6.219-8.56"/>
      </svg>
      <span class="text-[12px]">Initializing Monaco Editor...</span>
    </div>
  </div>
</div>
