---
// Sidebar: VS Code Explorer style
---

<aside id="app-sidebar"
  class="flex flex-col shrink-0 transition-all duration-200 overflow-hidden"
  style="width:var(--sidebar-width);background:var(--vscode-sidebar);border-right:1px solid var(--vscode-border);">

  <!-- Section title bar -->
  <div class="flex items-center justify-between px-3 py-[6px] shrink-0"
       style="border-bottom:1px solid var(--vscode-border);">
    <span class="text-[10px] font-semibold tracking-[1px] uppercase opacity-60" style="color:var(--vscode-text)">Explorer</span>
    <div class="flex gap-0.5">
      <!-- Hidden tab triggers for activity bar to click -->
      <button class="sidebar-tab-btn w-5 h-5 flex items-center justify-center rounded border-none cursor-pointer hover:bg-white/10 hidden" data-tab="explorer" style="background:transparent;color:var(--vscode-text-dim)"></button>
      <button class="sidebar-tab-btn w-5 h-5 flex items-center justify-center rounded border-none cursor-pointer hover:bg-white/10 hidden" data-tab="history" style="background:transparent;color:var(--vscode-text-dim)"></button>
      <button class="sidebar-tab-btn w-5 h-5 flex items-center justify-center rounded border-none cursor-pointer hover:bg-white/10 hidden" data-tab="settings" style="background:transparent;color:var(--vscode-text-dim)"></button>
    </div>
  </div>

  <!-- WORKSPACE section header -->
  <div id="sidebar-section-label"
       class="flex items-center gap-1.5 px-2 py-[5px] text-[11px] font-semibold uppercase tracking-wider cursor-default select-none shrink-0"
       style="color:var(--vscode-text);border-bottom:1px solid var(--vscode-border);">
    <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="opacity-60"><path d="M6 9l6 6 6-6"/></svg>
    <span id="sidebar-section-name">EXPLORER</span>
  </div>

  <!-- Scrollable content -->
  <div class="flex-1 overflow-y-auto">

    <!-- Explorer Panel (default) -->
    <div class="sidebar-panel block" id="panel-explorer">
      <!-- File actions -->
      <div class="flex items-center justify-end px-2 py-1 gap-1" style="border-bottom:1px solid rgba(255,255,255,0.05);">
        <button id="btn-new-file" class="w-6 h-6 flex items-center justify-center rounded cursor-pointer border-none transition-colors hover:bg-white/10" style="color:var(--vscode-text-dim);background:transparent;" title="New File">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="12" y1="18" x2="12" y2="12"/><line x1="9" y1="15" x2="15" y2="15"/></svg>
        </button>
        <button id="btn-new-folder" class="w-6 h-6 flex items-center justify-center rounded cursor-pointer border-none transition-colors hover:bg-white/10" style="color:var(--vscode-text-dim);background:transparent;" title="New Folder">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/><line x1="12" y1="11" x2="12" y2="17"/><line x1="9" y1="14" x2="15" y2="14"/></svg>
        </button>
      </div>
      <!-- Tree container -->
      <div id="vfs-tree" class="py-1"></div>
    </div>

    <!-- History Panel -->
    <div class="sidebar-panel hidden" id="panel-history">
      <div id="history-list-empty" class="flex flex-col items-center justify-center py-16 gap-2 opacity-50">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" style="color:var(--vscode-text-dim)"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3.5 3.5"/></svg>
        <span class="text-[12px]" style="color:var(--vscode-text-dim)">No history yet</span>
      </div>
      <div id="history-list" class="hidden py-1"></div>
    </div>

    <!-- Settings Panel -->
    <div class="sidebar-panel hidden py-3 px-3" id="panel-settings">
      <p class="text-[10px] uppercase tracking-wider mb-3 opacity-50 font-semibold" style="color:var(--vscode-text)">Editor Preferences</p>

      {[
        { id: 'setting-theme', label: 'Color Theme', opts: [['dark','Dark+ (default)'],['light','Light (Visual Studio)'],['cyberpunk','Cyberpunk Neon']] },
        { id: 'setting-fontsize', label: 'Font Size', opts: [['12','12px'],['14','14px (default)'],['16','16px'],['18','18px'],['20','20px']] },
        { id: 'setting-tabsize', label: 'Tab Size', opts: [['2','2 Spaces'],['4','4 Spaces'],['8','8 Spaces']] },
        { id: 'setting-wrap', label: 'Word Wrap', opts: [['on','On'],['off','Off']] },
        { id: 'setting-autorun', label: 'Auto Run', opts: [['debounce','On change (1s)'], ['off','Manual']] },
      ].map(s => (
        <div class="mb-4">
          <label class="block text-[11px] mb-1 opacity-70 font-medium" style="color:var(--vscode-text)" for={s.id}>{s.label}</label>
          <select id={s.id}
            class="w-full px-2 py-1.5 rounded-sm text-[12px] border outline-none transition-colors"
            style="background:var(--vscode-bg);color:var(--vscode-text);border-color:var(--vscode-border);">
            {s.opts.map(([val, lbl]) => (
              <option value={val}>{lbl}</option>
            ))}
          </select>
        </div>
      ))}
    </div>

  </div>
</aside>

<script>
  import { store, type VfsNode } from '../lib/store';
  import { getFileIcon, saveVFS, openFile, deleteNode, showToast, getTargetParentId } from '../lib/vfs';
  import { renderHistory } from '../lib/console';

  // Sidebar tab switching (triggered by activity bar)
  const tabs = document.querySelectorAll('.sidebar-tab-btn');
  const panels = document.querySelectorAll('.sidebar-panel');
  const sectionName = document.getElementById('sidebar-section-name');

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      panels.forEach(p => { p.classList.remove('block'); p.classList.add('hidden'); });
      const target = tab.getAttribute('data-tab');
      const panel = document.getElementById(`panel-${target}`);
      if (panel) { panel.classList.remove('hidden'); panel.classList.add('block'); }
      if (sectionName) sectionName.textContent = (target || '').toUpperCase();
    });
  });

  document.getElementById('btn-new-file')?.addEventListener('click', () => {
    store.setCreatingItem({ type: 'file', parentId: getTargetParentId() });
  });
  
  document.getElementById('btn-new-folder')?.addEventListener('click', () => {
    store.setCreatingItem({ type: 'folder', parentId: getTargetParentId() });
  });

  function renderVFS() {
    const tree = document.getElementById('vfs-tree');
    if (!tree) return;
    tree.innerHTML = '';
    
    tree.onclick = () => {
      store.setActiveFolderId(null);
      if (store.renamingItemId) store.setRenamingItemId(null);
    };

    const rootNodes = store.vfs.filter((n: VfsNode) => n.parentId === null);
    
    const renderNode = (node: VfsNode, level: number, container: HTMLElement) => {
      const el = document.createElement('div');
      el.className = 'flex items-center gap-1.5 px-2 py-[5px] cursor-pointer select-none transition-colors hover:bg-white/5 group relative';
      el.style.paddingLeft = `${level * 12 + 8}px`;
      if (node.id === store.activeFileId || node.id === store.activeFolderId) {
        el.style.background = 'rgba(255,255,255,0.1)';
      }
      
      const icon = document.createElement('span');
      icon.className = 'flex items-center justify-center shrink-0 w-[14px] h-[14px]';
      icon.innerHTML = getFileIcon(node.name, node.type);
      
      el.appendChild(icon);
      
      if (store.renamingItemId === node.id) {
        const input = document.createElement('input');
        input.type = 'text';
        input.className = 'flex-1 bg-transparent border border-[#007acc] text-[13px] outline-none text-white px-1';
        input.value = node.name;
        
        input.addEventListener('input', () => {
          icon.innerHTML = getFileIcon(input.value.trim(), node.type);
        });
        
        let committed = false;
        const commit = () => {
          if (committed) return;
          committed = true;
          const newName = input.value.trim();
          if (newName && newName !== node.name) {
            if (store.vfs.some((n: VfsNode) => n.name === newName && n.parentId === node.parentId && n.id !== node.id)) {
              showToast(`A ${node.type} named "${newName}" already exists in this folder.`, true);
              store.setRenamingItemId(null);
              return;
            }
            node.name = newName;
            saveVFS();
            if (store.activeFileId === node.id) {
              const label = document.getElementById('editor-title-label');
              if (label) label.textContent = newName;
            }
          }
          store.setRenamingItemId(null);
        };
        
        input.onkeydown = (e) => {
          if (e.key === 'Enter') commit();
          if (e.key === 'Escape') { store.setRenamingItemId(null); }
        };
        input.onblur = commit;
        
        el.appendChild(input);
        setTimeout(() => {
          input.focus();
          const dotIdx = input.value.lastIndexOf('.');
          if (dotIdx > 0) input.setSelectionRange(0, dotIdx);
          else input.select();
        }, 0);
      } else {
        const label = document.createElement('span');
        label.className = 'text-[13px] truncate flex-1';
        label.style.color = 'var(--vscode-text)';
        label.textContent = node.name;
        el.appendChild(label);
      }
      
      const actions = document.createElement('div');
      actions.className = 'hidden group-hover:flex items-center gap-1 absolute right-2 bg-[var(--vscode-sidebar)] px-1';
      
      if (store.renamingItemId !== node.id) {
        const renameBtn = document.createElement('button');
        renameBtn.className = 'w-[18px] h-[18px] flex items-center justify-center rounded border-none cursor-pointer hover:bg-white/10';
        renameBtn.style.color = 'var(--vscode-text-dim)';
        renameBtn.style.background = 'transparent';
        renameBtn.title = "Rename";
        renameBtn.innerHTML = `<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>`;
        renameBtn.onclick = (e) => {
          e.stopPropagation();
          store.setRenamingItemId(node.id);
        };
        actions.appendChild(renameBtn);
      }
      
      const delBtn = document.createElement('button');
      delBtn.className = 'w-[18px] h-[18px] flex items-center justify-center rounded border-none cursor-pointer hover:bg-red-500/80';
      delBtn.style.color = 'var(--vscode-text-dim)';
      delBtn.style.background = 'transparent';
      delBtn.title = "Delete";
      delBtn.innerHTML = `<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>`;
      delBtn.onclick = (e) => {
        e.stopPropagation();
        deleteNode(node.id);
      };
      
      if (store.renamingItemId !== node.id) actions.appendChild(delBtn);
      
      if (store.renamingItemId !== node.id) el.appendChild(actions);
      
      el.onclick = (e) => {
        e.stopPropagation();
        if (store.renamingItemId === node.id) return;
        if (node.type === 'file') {
          store.setActiveFolderId(null);
          openFile(node.id);
        } else {
          store.setActiveFolderId(store.activeFolderId === node.id ? null : node.id);
        }
      };
      
      container.appendChild(el);
      
      if (node.type === 'folder') {
        if (store.creatingItem && store.creatingItem.parentId === node.id) {
          renderInlineInput(store.creatingItem.type, store.creatingItem.parentId, container, level + 1);
        }
        const children = store.vfs.filter((n: VfsNode) => n.parentId === node.id);
        children.forEach(child => renderNode(child, level + 1, container));
      }
    };
    
    rootNodes.sort((a, b) => {
      if (a.type === b.type) return a.name.localeCompare(b.name);
      return a.type === 'folder' ? -1 : 1;
    });
    
    rootNodes.forEach(node => renderNode(node, 0, tree));
    
    if (store.creatingItem && store.creatingItem.parentId === null) {
      renderInlineInput(store.creatingItem.type, null, tree, 0);
    }
  }
  
  function renderInlineInput(type: 'file' | 'folder', parentId: string | null, container: HTMLElement, explicitLevel: number = 0) {
    let parentLevel = explicitLevel;

    const wrapper = document.createElement('div');
    wrapper.className = 'flex items-center gap-1.5 px-2 py-[5px]';
    wrapper.style.paddingLeft = `${parentLevel * 12 + 8}px`;
    
    const icon = document.createElement('span');
    icon.className = 'flex items-center justify-center shrink-0 w-[14px] h-[14px]';
    icon.innerHTML = getFileIcon('', type);
    
    const input = document.createElement('input');
    input.type = 'text';
    input.className = 'flex-1 bg-transparent border border-[#007acc] text-[13px] outline-none text-white px-1';
    input.placeholder = type === 'folder' ? 'Folder name' : 'File name';
    
    input.addEventListener('input', () => {
      icon.innerHTML = getFileIcon(input.value.trim(), type);
    });

    wrapper.appendChild(icon);
    wrapper.appendChild(input);
    
    container.appendChild(wrapper);
    input.focus();
    
    let committed = false;
    const commit = () => {
      if (committed) return;
      committed = true;
      const name = input.value.trim();
      if (name) {
        if (store.vfs.some((n: VfsNode) => n.name === name && n.parentId === parentId)) {
          showToast(`A ${type} named "${name}" already exists in this folder.`, true);
          store.setCreatingItem(null);
          return;
        }
        if (type === 'file') {
          const newFile: VfsNode = {
            id: 'f-' + Date.now(),
            name,
            type: 'file',
            content: '// ' + name + '\n',
            parentId
          };
          store.vfs.push(newFile);
          saveVFS();
          store.setCreatingItem(null);
          openFile(newFile.id);
        } else {
          const newFolder: VfsNode = {
            id: 'd-' + Date.now(),
            name,
            type: 'folder',
            parentId
          };
          store.vfs.push(newFolder);
          store.setActiveFolderId(newFolder.id);
          store.setCreatingItem(null);
          saveVFS();
        }
      } else {
        store.setCreatingItem(null);
      }
    };
    
    input.onkeydown = (e) => {
      if (e.key === 'Enter') commit();
      if (e.key === 'Escape') {
        store.setCreatingItem(null);
      }
    };
    
    input.onblur = commit;
  }

  // Subscribe to store events
  store.on('vfs-changed', renderVFS);
  store.on('active-file-changed', renderVFS);

  // Initial render when the script loads, though `initVFS` will be called from Compiler
  renderVFS();
</script>
