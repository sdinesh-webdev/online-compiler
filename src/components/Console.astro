---
// Console / Terminal panel — VS Code Panel style
---

<div id="app-console" class="flex flex-col relative" style="flex:0.7;min-height:160px;border-top:1px solid var(--vscode-border);background:var(--vscode-panel);">

  <!-- Panel Tab Bar -->
  <div class="flex items-center justify-between shrink-0" style="background:var(--vscode-sidebar);border-bottom:1px solid var(--vscode-border);height:var(--tabbar-height);">
    <div class="flex h-full">
      <button class="output-tab-btn flex items-center gap-1.5 px-4 h-full text-[12px] border-none border-b-2 border-transparent cursor-pointer transition-colors hover:bg-white/5 active"
        data-output-tab="console" style="background:var(--vscode-editor);color:var(--vscode-text);border-bottom-color:var(--vscode-accent);">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/></svg>
        Terminal
        <span class="text-[10px] px-1.5 py-px rounded-sm ml-0.5" id="console-count"
          style="background:var(--vscode-border);color:var(--vscode-text-dim)">0</span>
      </button>
      <button class="output-tab-btn flex items-center gap-1.5 px-4 h-full text-[12px] border-none border-b-2 border-transparent cursor-pointer transition-colors hover:bg-white/5"
        data-output-tab="preview" style="background:transparent;color:var(--vscode-text-dim);">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="1"/><path d="M3 9h18"/></svg>
        Preview
      </button>
    </div>

    <!-- Right controls -->
    <div class="flex items-center gap-1.5 px-3">
      <!-- Open Preview in New Tab -->
      <button id="btn-open-preview" title="Open Preview in New Tab"
        class="hidden w-6 h-6 flex items-center justify-center rounded border-none cursor-pointer transition-colors hover:bg-white/10"
        style="background:transparent;color:var(--vscode-text-dim);">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>
      </button>
      
      <!-- Filter input -->
      <div class="flex items-center gap-1.5 px-2 py-1 rounded-sm text-[12px]" style="background:var(--vscode-bg);border:1px solid var(--vscode-border);">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="color:var(--vscode-text-muted)"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input type="text" id="console-search" placeholder="Filter..." autocomplete="off"
          class="border-none outline-none bg-transparent text-[12px] w-24"
          style="color:var(--vscode-text);" />
      </div>
      <!-- Clear -->
      <button id="btn-clear-console" title="Clear Console"
        class="w-6 h-6 flex items-center justify-center rounded border-none cursor-pointer transition-colors hover:bg-white/10"
        style="background:transparent;color:var(--vscode-text-dim);">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
      </button>
    </div>
  </div>

  <!-- Content area -->
  <div class="flex-1 overflow-hidden relative">

    <!-- Console logs -->
    <div class="output-panel flex flex-col h-full" id="output-panel-console">
      <div class="flex-1 overflow-y-auto font-mono text-[12px] leading-[1.6]" id="console-logs" style="padding:6px 0;">
        <div class="flex flex-col items-center justify-center h-full gap-2 opacity-40" id="console-placeholder">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="color:var(--vscode-text-dim)"><polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/></svg>
          <span class="text-[12px]" style="color:var(--vscode-text-dim)">Press <strong>Run</strong> or <kbd style="background:var(--vscode-border);padding:1px 5px;border-radius:3px;font-size:11px;">Ctrl+Enter</kbd> to execute</span>
        </div>
      </div>

      <!-- REPL input -->
      <div class="flex items-center gap-2 px-3 shrink-0" style="height:28px;border-top:1px solid var(--vscode-border);background:var(--vscode-bg);">
        <span class="font-mono font-bold select-none text-[13px]" style="color:var(--vscode-accent)">›</span>
        <input type="text" id="repl-input-field" placeholder="Evaluate expression in sandbox..."
          autocomplete="off" spellcheck="false"
          class="flex-1 border-none outline-none bg-transparent font-mono text-[12px]"
          style="color:var(--vscode-text);" />
      </div>
    </div>

    <!-- Preview iframe panel -->
    <div class="output-panel hidden h-full" id="output-panel-preview">
      <iframe id="preview-iframe" class="w-full h-full border-none" style="background:#1e1e1e;"
        sandbox="allow-scripts"></iframe>
    </div>
  </div>
</div>

<style>
  .output-tab-btn.active {
    color: var(--vscode-text) !important;
    background: var(--vscode-editor) !important;
    border-bottom-color: var(--vscode-accent) !important;
  }
</style>

<script>
  // Tab switching
  document.querySelectorAll('.output-tab-btn').forEach(tab => {
    tab.addEventListener('click', () => {
      document.querySelectorAll('.output-tab-btn').forEach(t => t.classList.remove('active'));
      document.querySelectorAll('.output-panel').forEach(p => {
        p.classList.remove('flex', 'flex-col');
        p.classList.add('hidden');
      });
      tab.classList.add('active');
      
      const tabId = tab.getAttribute('data-output-tab');
      const panelId = `output-panel-${tabId}`;
      const panel = document.getElementById(panelId);
      if (panel) {
        panel.classList.remove('hidden');
        panel.classList.add('flex');
        if (panelId === 'output-panel-console') panel.classList.add('flex-col');
      }
      
      const btnOpenPreview = document.getElementById('btn-open-preview');
      if (btnOpenPreview) {
        if (tabId === 'preview') {
          btnOpenPreview.classList.remove('hidden');
        } else {
          btnOpenPreview.classList.add('hidden');
        }
      }
    });
  });
</script>
