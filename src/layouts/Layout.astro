<script is:inline>
(function () {
  // 1. Pre-seed deferred promise — resolved by Compiler.astro's AMD callback
  var _res;
  window._monacoReady   = new Promise(function (r) { _res = r; });
  window._resolveMonaco = function (m) { _res(m); };

  // 2. Check if engine was already downloaded on a previous visit
  var CACHE_FLAG = 'vscompiler_engine_v1';
  var isCached   = false;
  try { isCached = localStorage.getItem(CACHE_FLAG) === '1'; } catch (e) {}

  // 3. Helpers
  var STEPS = [
    'Bootstrapping compilation engine',
    'Initializing language services',
    'Configuring workspace & toolchain',
    'Mounting development environment'
  ];

  function setText(msg) {
    var el = document.getElementById('bl-status-text');
    if (!el) return;
    el.style.opacity = '0';
    setTimeout(function () { el.textContent = msg; el.style.opacity = '1'; }, 140);
  }

  function setDots(idx) {
    for (var i = 0; i < 4; i++) {
      var d = document.getElementById('bl-dot-' + i);
      if (!d) continue;
      if (i < idx)      d.className = 'bl-dot done';
      else if (i === idx) d.className = 'bl-dot active';
      else               d.className = 'bl-dot';
    }
  }

  function setStep(idx) {
    setText(STEPS[Math.min(idx, STEPS.length - 1)]);
    setDots(idx);
  }

  function setPct(pct) {
    var p    = Math.min(100, Math.max(0, pct));
    var fill = document.getElementById('bl-fill');
    var glow = document.getElementById('bl-glow');
    var pctEl = document.getElementById('bl-pct');
    if (fill)  fill.style.width = p + '%';
    if (glow)  glow.style.left  = 'calc(' + p + '% - 26px)';
    if (pctEl) pctEl.textContent = Math.round(p) + '%';
    return p;
  }

  function setBytes(txt) {
    var el = document.getElementById('bl-bytes');
    if (el) el.textContent = txt;
  }

  function fmtBytes(n) {
    if (n >= 1048576) return (n / 1048576).toFixed(1) + ' MB';
    if (n >= 1024)    return (n / 1024).toFixed(0) + ' KB';
    return n + ' B';
  }

  function dismiss() {
    var el = document.getElementById('app-boot-loader');
    if (!el) return;
    el.classList.add('hidden');
    setTimeout(function () { if (el.parentNode) el.parentNode.removeChild(el); }, 700);
  }

  // 4a. CACHED — engine in browser disk cache, load is near-instant
  if (isCached) {
    setBytes('');
    setPct(82);
    setDots(4); // all done
    setText('Starting workspace');

    var fp = 82;
    var tid = setInterval(function () {
      if (fp < 97) { fp += 1.5; setPct(fp); }
      else clearInterval(tid);
    }, 25);

    window._monacoReady.then(function () {
      clearInterval(tid);
      setPct(100);
      setTimeout(dismiss, 320);
    });

    return; // skip fetch
  }

  // 4b. FIRST VISIT — stream fetch with real byte progress
  setPct(2);
  setStep(0);
  setTimeout(function () { setStep(1); }, 100);

  var BASE   = 'https://cdnjs.cloudflare.com/ajax/libs/monaco-editor/0.52.2/min/vs';
  var URL    = BASE + '/editor/editor.main.js';
  var APPROX = 5.2 * 1024 * 1024;

  // cache:'default' lets browser cache the response (cdnjs: max-age=1yr)
  // so subsequent AMD loads come from disk, not network
  fetch(URL, { cache: 'default' })
    .then(function (res) {
      var cl     = parseInt(res.headers.get('content-length') || '0', 10);
      var total  = cl > 0 ? cl : APPROX;
      var loaded = 0;
      var reader = res.body.getReader();

      setStep(2);

      function pump() {
        return reader.read().then(function (chunk) {
          if (chunk.done) return;
          loaded += chunk.value.length;
          setPct(5 + (Math.min(loaded / total, 1) * 80));
          setBytes(fmtBytes(loaded) + ' / ' + fmtBytes(total));
          return pump();
        });
      }

      return pump().then(function () {
        setPct(88);
        setBytes(fmtBytes(total) + ' / ' + fmtBytes(total));
        setStep(3);
      });
    })
    .catch(function () {
      setPct(88);
      setBytes('');
      setStep(3);
    })
    .then(function () {
      var fp = 88;
      var tid = setInterval(function () {
        if (fp < 95) { fp += 0.3; setPct(fp); }
        else clearInterval(tid);
      }, 36);

      window._monacoReady.then(function () {
        clearInterval(tid);
        setPct(100);
        setBytes('');
        setText('Workspace ready');
        try { localStorage.setItem(CACHE_FLAG, '1'); } catch (e) {}
        setTimeout(dismiss, 750);
      });
    });
}());
</script>
